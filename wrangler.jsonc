{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "midnightsignals",
  "compatibility_date": "2026-06-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application",
    "html_handling": "none"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
